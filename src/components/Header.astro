---
let avatarUrl =
	'https://github.com/dampuzakura/dampuzakura/blob/main/avatar.png?raw=true';
---

<header class='bg-blue-900 text-gray-100 body-font'>
	<div
		class='container mx-auto flex flex-wrap p-5 flex-col md:flex-row items-center'
	>
		<a class='flex title-font font-medium items-center mb-4 md:mb-0'>
			<img class='w-10 h-10 rounded-full' src={avatarUrl} />
			<span class='ml-3 text-3xl'>段風桜</span>
		</a>
		<nav
			class='md:ml-auto flex flex-wrap items-center text-base justify-center'
		>
			<a class='mr-5 hover:text-gray-400' href='#'>トップ</a>
			<a class='mr-5 hover:text-gray-400' href='#whoami'>私は誰</a>
			<a class='mr-5 hover:text-gray-400' href='#project'>プロジェクト</a>
			<a class='mr-5 hover:text-gray-400' href='#sns'>SNS</a>
		</nav>
	</div>
</header>
